{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "sh mvnw -B package -DskipTests",
    "variables": {
      "RAILPACK_JDK_VERSION": "21"
    }
  },
  "deploy": {
    "startCommand": "java -jar target/lostfound-0.0.1-SNAPSHOT.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}